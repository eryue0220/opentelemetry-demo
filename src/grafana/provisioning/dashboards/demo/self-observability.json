{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "OpenTelemetry self-observability: internal metrics emitted by the OpenTelemetry SDKs themselves (experimental `otel.sdk.*` semantic conventions). Works for any service that opts in to SDK self-monitoring; new services appear automatically via the Service template variable.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Number of services currently emitting OpenTelemetry SDK self-observability metrics.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": 0 } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "count(group by (service_name) ({__name__=~\"otel_sdk_.+\",service_name=~\"$service_name\"}))",
          "instant": true,
          "legendFormat": "Services",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Services reporting",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of spans that finished exporting successfully (`error_type` empty) across the selected services. See \"Export errors\" for the failed portion of the same counter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": 0 } ] },
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(otel_sdk_exporter_span_exported_total{service_name=~\"$service_name\",error_type=\"\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "Spans exported",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spans exported",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of metric data points that finished exporting successfully (`error_type` empty) across the selected services. See \"Export errors\" for the failed portion of the same counter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "purple", "value": 0 } ] },
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 5 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(otel_sdk_exporter_metric_data_point_exported_total{service_name=~\"$service_name\",error_type=\"\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "Data points exported",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Metric data points exported",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of LogRecords that finished exporting successfully (`error_type` empty) across the selected services. See \"Export errors\" for the failed portion of the same counter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": 0 } ] },
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(otel_sdk_exporter_log_exported_total{service_name=~\"$service_name\",error_type=\"\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "LogRecords exported",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "LogRecords exported",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of spans, LogRecords, and metric data points whose export attempt finished with `error_type` set (the failed complement of the three \"exported\" panels above). A non-zero value means the exporter could not deliver telemetry to the collector/backend.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": 0 }, { "color": "red", "value": 0.001 } ] },
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 5 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(otel_sdk_exporter_span_exported_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval])) + sum(rate(otel_sdk_exporter_log_exported_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval])) + sum(rate(otel_sdk_exporter_metric_data_point_exported_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "Export errors",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Export errors",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Telemetry items (spans, LogRecords, and metric data points) currently passed to an exporter but not yet exported (in-flight), summed across all signals.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": 0 } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(otel_sdk_exporter_span_inflight{service_name=~\"$service_name\"}) + sum(otel_sdk_exporter_log_inflight{service_name=~\"$service_name\"}) + sum(otel_sdk_exporter_metric_data_point_inflight{service_name=~\"$service_name\"})",
          "instant": false,
          "legendFormat": "In-flight",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Items in-flight",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of spans and LogRecords DROPPED by their processor's queue before ever reaching the exporter (spans + LogRecords only -- metrics have no processor stage). A non-zero value means `queue_full` or `already_shutdown` drops are happening; see the per-signal \"processed error rate\" panels in the Span pipeline / Log pipeline rows below for the breakdown.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": 0 }, { "color": "red", "value": 0.001 } ] },
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 9 },
      "id": 69,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(otel_sdk_processor_span_processed_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval])) + sum(rate(otel_sdk_processor_log_processed_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "Processing errors (spans + LogRecords)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Processing errors (spans + LogRecords)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "panels": [],
      "title": "Span pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of spans started by the SDK (`otel.sdk.span.started`). Includes non-recording spans.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 21,
      "options": { "legend": { "calcs": [ "lastNotNull" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(otel_sdk_span_started_total{service_name=~\"$service_name\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spans started rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Number of live (started but not yet ended) recording spans (`otel.sdk.span.live`).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 22,
      "options": { "legend": { "calcs": [ "lastNotNull" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name) (otel_sdk_span_live{service_name=~\"$service_name\"})",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Live spans",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Batch span processor queue utilization: current queue size as a fraction of capacity (`otel.sdk.processor.span.queue.size` / `otel.sdk.processor.span.queue.capacity`). At 100% the queue is full and the processor starts dropping new spans (reported as `error_type=\"queue_full\"` in the \"Spans processed error rate\" panel below).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 23,
      "options": { "legend": { "calcs": [ "lastNotNull", "max" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name, otel_component_name) (otel_sdk_processor_span_queue_size{service_name=~\"$service_name\"}) / sum by (service_name, otel_component_name) (otel_sdk_processor_span_queue_capacity{service_name=~\"$service_name\"})",
          "legendFormat": "{{service_name}} / {{otel_component_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Span processor queue utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of spans that were DROPPED by the span processor (never reached the exporter), broken down by `error.type` (this panel excludes the success case -- see \"Spans started rate\" for total volume). `error_type` is `queue_full` (the processor's queue was full) or `already_shutdown` (submitted after the processor was shut down). Should be flat zero in a healthy system.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } },
          "mappings": [],
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "id": 24,
      "options": { "legend": { "calcs": [ "lastNotNull" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name, error_type) (rate(otel_sdk_processor_span_processed_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{error_type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spans processed error rate (by error type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of FAILED span export operations, broken down by `error.type` (this panel excludes the success case -- see \"Spans exported\" in the Overview row for the success rate). A non-zero value means the export call itself failed, e.g. `timeout` or a connection error -- distinct from processor-side `queue_full` drops shown in \"Spans processed error rate\" above. Should be flat zero in a healthy system.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } },
          "mappings": [],
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "id": 25,
      "options": { "legend": { "calcs": [ "lastNotNull" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name, error_type) (rate(otel_sdk_exporter_span_exported_total{service_name=~\"$service_name\",error_type!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{error_type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spans exported error rate (by error type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Spans passed to an exporter but not yet exported (`otel.sdk.exporter.span.inflight`).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "id": 26,
      "options": { "legend": { "calcs": [ "lastNotNull", "max" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name) (otel_sdk_exporter_span_inflight{service_name=~\"$service_name\"})",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spans in-flight",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Average duration of the span exporter's export call (`otel.sdk.exporter.operation.duration`, filtered to span exporters). Distinct from \"Spans exported error rate\", which measures success/failure, not latency. Shown as an average (sum/count) rather than a percentile because the SDK currently reports this histogram with a single `+Inf` bucket, which makes `histogram_quantile` always return NaN.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "id": 66,
      "options": { "legend": { "calcs": [ "lastNotNull", "max" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name, otel_component_type) (rate(otel_sdk_exporter_operation_duration_seconds_sum{service_name=~\"$service_name\",otel_component_type=~\".*span_exporter\"}[$__rate_interval])) / sum by (service_name, otel_component_type) (rate(otel_sdk_exporter_operation_duration_seconds_count{service_name=~\"$service_name\",otel_component_type=~\".*span_exporter\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{otel_component_type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Span export operation duration (avg)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 60,
      "panels": [],
      "title": "Log pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Rate of LogRecords submitted to enabled SDK loggers (`otel.sdk.log.created`).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "none" } },
          "mappings": [],
          "unit": "items/sec"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 },
      "id": 61,
      "options": { "legend": { "calcs": [ "lastNotNull" ], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(otel_sdk_log_created_total{service_name=~\"$service_name\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "LogRecords created rate",
      "type": "timeseries"
    },
    {
